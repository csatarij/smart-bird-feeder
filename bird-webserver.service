[Unit]
Description=Smart Bird Feeder — Photo Browser & Health Dashboard
After=network.target bird-capture.service bird-classify.service

[Service]
Type=simple
User=csatarij
WorkingDirectory=/home/csatarij/smart-bird-feeder
ExecStart=/home/csatarij/smart-bird-feeder/venv/bin/python3 webserver.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

MemoryMax=100M

[Install]
WantedBy=multi-user.target
