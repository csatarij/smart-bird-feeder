[Unit]
Description=Smart Bird Feeder — Motion Capture
After=network.target
Wants=bird-classify.service

[Service]
Type=simple
User=csatarij
WorkingDirectory=/home/csatarij/smart-bird-feeder
ExecStart=/home/csatarij/smart-bird-feeder/venv/bin/python3 motion_detector.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# Ensure all child processes are killed on stop/restart
KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=15

# Resource limits suitable for Pi 1B
MemoryMax=200M
CPUQuota=60%

[Install]
WantedBy=multi-user.target
